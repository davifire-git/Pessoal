<?xml version="1.0" encoding="UTF-8"?>
<!--
  SITEMAP.XML — Mapa do site para os robôs do Google
  ====================================================
  Este arquivo lista todas as páginas do site para que o Google
  as encontre e indexe mais rapidamente.
  
  Após publicar, cadastre este arquivo no Google Search Console em:
  https://search.google.com/search-console
  Vá em "Sitemaps" e cole: https://www.ilkarepsi.com/sitemap.xml
-->

<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <!-- ===== PÁGINA PRINCIPAL ===== -->
  <url>
    <!-- loc: endereço completo da página -->
    <loc>https://www.ilkarepsi.com/</loc>

    <!-- lastmod: data da última modificação (formato AAAA-MM-DD) -->
    <!-- Atualize esta data sempre que fizer mudanças importantes no site -->
    <lastmod>2026-06-30</lastmod>

    <!-- changefreq: com que frequência o conteúdo muda -->
    <!-- Valores possíveis: always | hourly | daily | weekly | monthly | yearly | never -->
    <changefreq>monthly</changefreq>

    <!-- priority: importância desta página em relação às outras (0.0 a 1.0) -->
    <!-- A página principal sempre recebe 1.0 (máxima prioridade) -->
    <priority>1.0</priority>
  </url>

  <!-- ===== PÁGINA SOBRE ===== -->
  <url>
    <loc>https://www.ilkarepsi.com/sobre.html</loc>
    <lastmod>2026-06-30</lastmod>
    <!-- weekly = o Google vai verificar esta página semanalmente por atualizações -->
    <changefreq>monthly</changefreq>
    <!-- 0.8 = alta prioridade, segunda mais importante depois da home -->
    <priority>0.8</priority>
  </url>

  <!-- ===== SEÇÕES DA PÁGINA PRINCIPAL (âncoras) ===== -->
  <!-- Opcional: listamos as seções para reforçar as âncoras para o Google -->

  <url>
    <loc>https://www.ilkarepsi.com/#servicos</loc>
    <lastmod>2026-06-30</lastmod>
    <changefreq>monthly</changefreq>
    <!-- 0.7 = prioridade média-alta (seção de serviços é importante para conversão) -->
    <priority>0.7</priority>
  </url>

  <url>
    <loc>https://www.ilkarepsi.com/#como-funciona</loc>
    <lastmod>2026-06-30</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>

  <url>
    <loc>https://www.ilkarepsi.com/#contato</loc>
    <lastmod>2026-06-30</lastmod>
    <changefreq>monthly</changefreq>
    <!-- 0.9 = quase tão importante quanto a home, pois é onde o cliente converte -->
    <priority>0.9</priority>
  </url>

</urlset>
